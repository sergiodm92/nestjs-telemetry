{
  "name": "@nestjs-telemetry/core",
  "version": "0.1.0",
  "description": "Zero-config real-time debugging dashboard for NestJS",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && npm run copy:dashboard",
    "copy:dashboard": "node -e \"const fs=require('fs');fs.mkdirSync('dist/dashboard',{recursive:true});fs.copyFileSync('src/dashboard/index.html','dist/dashboard/index.html')\"",
    "prepublishOnly": "npm run build",
    "test": "jest --config jest.config.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/schedule": {
      "optional": true
    },
    "@nestjs/cache-manager": {
      "optional": true
    },
    "@nestjs/event-emitter": {
      "optional": true
    },
    "@nestjs-modules/mailer": {
      "optional": true
    }
  }
}
